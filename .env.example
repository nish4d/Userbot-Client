# Telegram API Credentials - Get from https://my.telegram.org
NEXT_PUBLIC_TELEGRAM_API_ID=your_api_id_here
NEXT_PUBLIC_TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+your_phone_number_here

# MongoDB Connection String
MONGODB_URL=your_mongodb_connection_string_here

# Server Port (optional, defaults to 8000)
PORT=8000

# API Base URL (optional, defaults to https://userbot-blue.vercel.app)
NEXT_PUBLIC_API_BASE_URL=https://userbot-blue.vercel.app

# Debug Mode (optional)
DEBUG=userbot:*